# Optional local overrides used by several shell launchers.
# Copy to .env for local experiments; .env is ignored by Git.

PYTHON=/path/to/conda/envs/verl/bin/python
VERL_HOME=$HOME/verl

MODEL_PATH=$HOME/models/coder_1_5b_sft_warmup/final
TRAIN_FILE=$HOME/data/mbpp_v2/mbpp_train.parquet
TEST_FILE=$HOME/data/mbpp_v2/mbpp_test.parquet

PROJECT_NAME=verl_grpo_mbpp_v2
EXPERIMENT_NAME=local_experiment
LOG_FILE=$HOME/codellmRL/train.log
